{
  "version": 2,
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "functions": {
    "api/index.js": {
      "memory": 512,
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js?path=$1"
    },
    {
      "source": "/((?!api/|assets/|icons/|sounds/|map/|manifest.webmanifest|sw.js|vite.svg|favicon.ico).*)",
      "destination": "/index.html"
    }
  ]
}
# ============================================================
# Nukus Go — Environment Variables
# .env.local yoki Vercel Dashboard > Settings > Env Vars
# ============================================================

# ─── Frontend (VITE_ prefix majburiy) ───────────────────────
VITE_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Web Push VAPID public key (npx web-push generate-vapid-keys)
VITE_VAPID_PUBLIC_KEY=BNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# API base URL (local dev uchun bo'sh qoldiring)
VITE_API_BASE=

# ─── Backend / Vercel Serverless Functions ────────────────────
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Web Push VAPID (npx web-push generate-vapid-keys)
VAPID_SUBJECT=mailto:admin@nukusgo.uz
VAPID_PUBLIC_KEY=BNxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
VAPID_PRIVATE_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Cron endpoint himoyasi (ixtiyoriy, lekin tavsiya etiladi)
CRON_SECRET=super-secret-random-string-here

# ─── Ixtiyoriy ────────────────────────────────────────────────
# Python AI backend (Render yoki Railway'da deploy bo'lsa)
PYTHON_AI_URL=https://your-ai-backend.railway.app
VITE_PYTHON_AI_URL=https://your-ai-backend.railway.app

# OpenWeatherMap API (surge ob-havo uchun — ixtiyoriy, bepul tier mavjud)
# https://openweathermap.org/api → My API keys
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Redis (BullMQ yoki rate limiting uchun — Upstash tavsiya etiladi)
REDIS_URL=redis://default:password@hostname:6379

# Auth qo'shimcha xavfsizlik (JWT signing uchun)
AUTH_SECRET=change-this-to-random-64-char-string

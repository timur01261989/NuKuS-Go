VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
\nVITE_ROUTING_PROVIDER=ors\nVITE_ORS_API_KEY=\nVITE_VALHALLA_BASE_URL=http://127.0.0.1:8002\n
# API base (leave empty on Vercel to use same origin)
VITE_API_BASE=
# Vercel env (backend)
AUTH_SECRET=change-me

SUPABASE_SERVICE_ROLE_KEY=
# (Optional) Use Vercel Cron to call:
# /api/cron-expire-orders
# /api/offer-timeout

# Providers (default: OSM/OSRM)
VITE_MAP_PROVIDER=OSM
VITE_ROUTE_PROVIDER=OSRM
VITE_TRAFFIC_PROVIDER=NONE

# OSRM base URL
VITE_OSRM_BASE_URL=https://router.project-osrm.org


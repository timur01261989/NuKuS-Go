# UniGo (Vercel) - unified env template
# Serverless API uses SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY (or SUPABASE_SERVICE_KEY fallback).

# --- Supabase ---
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SERVICE_KEY=
VITE_SUPABASE_URL=

# --- Frontend ---
VITE_API_BASE_URL=/api
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAPBOX_TOKEN=
VITE_APP_VERSION=

# --- SMS / OTP ---
SMS_GATEWAY_URL=
SMS_GATEWAY_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# --- Payments ---
PAYMENT_GATEWAY_URL=
PAYMENT_MERCHANT_ID=
PAYMENT_SECRET_KEY=

# --- Notifications (WebPush) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=

# --- Server ---
NODE_ENV=production
HOST=0.0.0.0
CORS_ORIGIN=*
ALLOWED_ORIGINS=*
UPLOAD_DIR=uploads
REDIS_URL=

# --- AI (optional) ---
AI_MODE=off
PY_AI_URL=

# UniGo - unified environment variables
# Copy this file to .env and fill in values.

# ---------------------------
# Frontend (Vite)
# ---------------------------
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=xxxxx
VITE_API_BASE_URL=http://localhost:4000
VITE_APP_VERSION=1.0.0

# ---------------------------
# Server / API (Node)
# ---------------------------
SUPABASE_URL=https://xxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxxx
SUPABASE_ANON_KEY=xxxxx

PORT=4000
CORS_ORIGIN=http://localhost:5173

# Redis (optional)
REDIS_URL=redis://127.0.0.1:6379

# Storage
UPLOAD_DIR=./uploads

# Push notifications (optional)
VAPID_PUBLIC_KEY=xxxxx
VAPID_PRIVATE_KEY=xxxxx
VAPID_SUBJECT=mailto:admin@example.com

# SMS (optional - Twilio)
TWILIO_ACCOUNT_SID=xxxxx
TWILIO_AUTH_TOKEN=xxxxx
TWILIO_PHONE=+10000000000

# AI integration (optional)
AI_MODE=mock   # mock | python
PY_AI_URL=http://127.0.0.1:8000
HOST=127.0.0.1


# --- Legacy/compat (from older unigo_full) ---
ALLOWED_ORIGINS=
NODE_ENV=
PAYMENT_GATEWAY_URL=
PAYMENT_MERCHANT_ID=
PAYMENT_SECRET_KEY=
SMS_GATEWAY_API_KEY=
SMS_GATEWAY_URL=
SUPABASE_SERVICE_KEY=
VITE_GOOGLE_MAPS_API_KEY=
VITE_MAPBOX_TOKEN=

# NOTE: Prefer SUPABASE_SERVICE_ROLE_KEY. SUPABASE_SERVICE_KEY kept for backward compatibility.

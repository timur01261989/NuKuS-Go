# ════════════════════════════════════════════════════════════
# UniGo Platform v7 — Environment Variables (COMPLETE)
# ════════════════════════════════════════════════════════════

# ── Supabase ─────────────────────────────────────────────────
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──────────────────────────────────────────────────────
VITE_APP_NAME=UniGo
VITE_APP_VERSION=7.0.0
VITE_APP_ENV=production
VITE_AUTO_MARKET_MODE=real

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://unigo:secret@localhost:5432/unigo
DB_HOST=localhost
DB_PORT=5432
DB_USER=unigo
DB_PASSWORD=secret
DB_NAME=unigo

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── Kafka ────────────────────────────────────────────────────
KAFKA_BROKERS=kafka:9092
KAFKA_CLIENT_ID=unigo-service

# ── ClickHouse ───────────────────────────────────────────────
CLICKHOUSE_URL=http://clickhouse:8123
CLICKHOUSE_DB=unigo
CLICKHOUSE_USER=default
CLICKHOUSE_PASSWORD=

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTIC_PASSWORD=

# ── API Gateway ──────────────────────────────────────────────
VITE_API_BASE_URL=https://api.unigo.uz
VITE_WS_URL=wss://ws.unigo.uz
JWT_SECRET=your-super-secret-jwt-key-minimum-32-characters
CLIENT_ORIGIN=https://unigo.uz

# ── Service URLs (Docker internal) ──────────────────────────
AUTH_SERVICE_URL=http://auth-service:3001
RIDE_SERVICE_URL=http://ride-service:3002
DELIVERY_SERVICE_URL=http://delivery-service:3003
PAYMENT_SERVICE_URL=http://payment-service:3004
LOCATION_SERVICE_URL=http://location-service:3005
NOTIFICATION_SERVICE_URL=http://notification-service:3006
FREIGHT_SERVICE_URL=http://freight-service:3007
INTERCITY_SERVICE_URL=http://intercity-service:3008
MARKETPLACE_SERVICE_URL=http://marketplace-service:3009
FOOD_SERVICE_URL=http://food-service:3011
INTERDISTRICT_SERVICE_URL=http://interdistrict-service:3012
ANALYTICS_SERVICE_URL=http://analytics-service:3013
SEARCH_SERVICE_URL=http://search-service:3014
MATCHING_SERVICE_URL=http://matching-service:3015
REWARD_SERVICE_URL=http://reward-service:3016
ROUTING_SERVICE_URL=http://routing-service:3017
CORPORATE_SERVICE_URL=http://corporate-service:3018
SAFETY_SERVICE_URL=http://safety-service:3019
SUBSCRIPTION_SERVICE_URL=http://subscription-service:3020
VERIFICATION_SERVICE_URL=http://verification-service:3021
PROMO_SERVICE_URL=http://promo-service:3022
WS_GATEWAY_URL=http://ws-gateway:3010
ML_SERVICE_URL=http://ml-service:8000

# ── Payment Providers ─────────────────────────────────────────
PAYME_MERCHANT_ID=your-payme-merchant-id
PAYME_SECRET_KEY=your-payme-secret
CLICK_SERVICE_ID=your-click-service-id
CLICK_MERCHANT_ID=your-click-merchant-id
CLICK_SECRET_KEY=your-click-secret

# ── Notifications ─────────────────────────────────────────────
FCM_SERVER_KEY=your-fcm-server-key
ESKIZ_EMAIL=your@email.com
ESKIZ_PASSWORD=your-eskiz-password
VITE_VAPID_PUBLIC_KEY=your-vapid-public-key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@unigo.uz
SMTP_PASS=your-smtp-password

# ── ML / Routing ──────────────────────────────────────────────
OSRM_URL=http://router.project-osrm.org
YANDEX_TRAFFIC_API_KEY=your-yandex-traffic-key

# ── Observability ─────────────────────────────────────────────
GRAFANA_PASSWORD=admin_secure_password
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project

# ── Secrets / Vault ───────────────────────────────────────────
VAULT_TOKEN=dev-root-token
VAULT_URL=http://vault:8200

# ── Vercel ────────────────────────────────────────────────────
VERCEL_TOKEN=your-vercel-token
VERCEL_ORG_ID=your-org-id
VERCEL_PROJECT_ID=your-project-id

# ── Kubernetes ────────────────────────────────────────────────
# KUBECONFIG stored as GitHub secret

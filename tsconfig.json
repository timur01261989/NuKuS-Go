        "./libs/zod-schemas/src/index.ts"
      ],
      "@unigo/event-bus": [
        "./libs/event-bus/src/index.ts"
      ],
      "@unigo/cache-lib": [
        "./libs/cache-lib/src/index.ts"
      ],
      "@unigo/geo-lib": [
        "./libs/geo-lib/src/index.ts"
      ],
      "@unigo/feature-flags-lib": [
        "./libs/feature-flags-lib/src/index.ts"

{
  "name": "unigo-platform",
  "version": "11.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "libs/*",
    "testing"
  ],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "dev:client": "turbo run dev --filter=@unigo/client-app",
    "dev:admin": "turbo run dev --filter=@unigo/admin-panel",
    "dev:gateway": "turbo run dev --filter=@unigo/api-gateway",
    "dev:ws": "turbo run dev --filter=@unigo/ws-gateway",
    "dev:ml": "cd apps/ml-service && uvicorn main:app --reload --port 8000",
    "build:client": "turbo run build --filter=@unigo/client-app",
    "build:services": "turbo run build --filter=./services/*",
    "build:all": "turbo run build",
    "test:unit": "cd testing && npm test",
    "test:e2e": "cd testing && npm run test:e2e",
    "docker:up": "cd infrastructure && docker-compose up -d",
    "docker:down": "cd infrastructure && docker-compose down",
    "docker:build": "cd infrastructure && docker-compose build",
    "docker:logs": "cd infrastructure && docker-compose logs -f",
    "db:migrate": "bash infrastructure/ci-cd/scripts/db-migrate.sh",
    "db:push": "cd infrastructure/db/prisma && npx prisma db push",
    "db:studio": "cd infrastructure/db/prisma && npx prisma studio",
    "kafka:topics": "docker exec kafka bash /opt/topics.sh",
    "dev:chat": "turbo run dev --filter=@unigo/chat-service",
    "dev:wallet": "turbo run dev --filter=@unigo/wallet-service",
    "dev:earnings": "turbo run dev --filter=@unigo/earnings-service",
    "test:load": "k6 run testing/load/ride-load-test.js",
    "backup": "bash infrastructure/ci-cd/scripts/backup.sh",
    "dev:graphql": "turbo run dev --filter=@unigo/graphql-gateway",
    "dev:voice": "turbo run dev --filter=@unigo/voice-service",
    "edge:deploy": "cd apps/edge-functions && wrangler deploy",
    "edge:dev": "cd apps/edge-functions && wrangler dev",
    "db:migrate:all": "for f in infrastructure/db/postgres/migrations/*.sql; do psql $DATABASE_URL -f $f; done",
    "dev:sdui": "turbo run dev --filter=@unigo/sdui-service",
    "dev:features": "turbo run dev --filter=@unigo/feature-store-service",
    "chaos:apply": "kubectl apply -f infrastructure/chaos/chaos-mesh.yaml",
    "nginx:reload": "nginx -s reload",
    "migrate:all": "for f in infrastructure/db/postgres/migrations/*.sql; do psql $DATABASE_URL -f $f; done",
    "shadow:apply": "kubectl apply -f infrastructure/k8s/service-mesh/traffic-shadowing.yaml",
    "dev:support": "turbo run dev --filter=@unigo/support-service",
    "dev:fleet": "turbo run dev --filter=@unigo/fleet-service",
    "dev:rating": "turbo run dev --filter=@unigo/rating-service",
    "dev:report": "turbo run dev --filter=@unigo/report-service",
    "dev:config": "turbo run dev --filter=@unigo/config-service",
    "dev:all": "turbo run dev",
    "health:check": "curl -s http://localhost:8080/api/health/services | python3 -m json.tool",
    "report:daily": "curl -X POST http://localhost:3034/reports/daily",
    "config:init": "curl -X POST http://localhost:3035/config/init"
  },
  "devDependencies": {
    "turbo": "^1.13.0",
    "typescript": "^5.4.0",
    "eslint": "^8.57.0",
    "prettier": "^3.2.5",
    "prisma": "^5.13.0"
  },
  "engines": {
    "node": ">=20"
  },
  "description": "UniGo Super App \u2014 Production Platform v11 (Uber/Yandex Level)"
}